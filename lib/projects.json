{
  "example-embed": {
    "id": "example-embed",
    "name": "Example Embed",
    "description": "Minimal embed preset: 3D only, source panels hidden, hillshade + hypsometric tint on by default.",
    "disableViewModes": ["2d", "globe"],
    "initialViewMode": "3d",
    "hideSourcePanels": true,
    "initialState": {
      "showHillshade": true,
      "showColorRelief": true
    },
    "initialSections": {
      "general": false,
      "visualizationModes": true,
      "download": false
    }
  },
  "mapterhorn-globe": {
    "id": "mapterhorn-globe",
    "name": "Mapterhorn Globe",
    "description": "Minimal globe view zoomed out to the whole world, Mapterhorn as the only terrain source, source pickers hidden.",
    "initialViewMode": "globe",
    "hideSourcePanels": true,
    "initialState": {
      "sourceA": "mapterhorn",
      "lat": 15,
      "lng": 10,
      "zoom": 3.3,
      "pitch": 0,
      "bearing": 0,
      "showColorRelief": true,
      "colorReliefOpacity": 0.2
    },
    "initialSections": {
      "hillshade": true
    }
  },
  "dura": {
    "id": "dura",
    "name": "Dura Frescoes Viewer",
    "description": "Dura Europos Synagogue COG terrain + basemap (W-0.5mm), fixed 2D view over the site, hillshade on (hypsometric tint off), raster basemap at 20% opacity, contours/Slope-and-More/split-screen/elevation-picker off and hidden, 2D/3D view modes only (no globe), sidebar closed by default, source pickers hidden, Visualization Modes and Hillshade Options sections open, map controls disabled.",
    "hideSourcePanels": true,
    "hiddenSections": ["contour", "slopeAndMore", "splitScreen", "elevationPicker"],
    "disableViewModes": ["globe"],
    "hideMapControls": ["geocoder", "zoom", "geolocate", "minimap", "scale"],
    "initialState": {
      "sourceA": "dura-w-05mm",
      "basemapSource": "dura-w-05mm",
      "basemapSourceA": "dura-w-05mm",
      "basemapPerView": false,
      "showContoursAndGraticules": false,
      "showSlopeAndMore": false,
      "showHillshade": true,
      "showColorRelief": false,
      "showRasterBasemap": true,
      "rasterBasemapOpacity": 0.2,
      "viewMode": "2d",
      "lat": -0.1472,
      "lng": 0.2672,
      "zoom": 11.6,
      "pitch": 0
    },
    "initialSidebarOpen": false,
    "initialSections": {
      "visualizationModes": true,
      "hillshade": true
    },
    "customTerrainSources": [
      {
        "id": "dura-w-05mm",
        "name": "Dura Synagogue - W-0.5mm DSM",
        "url": "https://3d.iconem.com/syria/DuraEuropos_Synagogue/DuraEuropos_Synagogue_W_0.5mm_DSM_fakegeo.cog.tiff",
        "type": "cog",
        "description": ""
      }
    ],
    "customBasemapSources": [
      {
        "id": "dura-w-05mm",
        "name": "Dura Synagogue - W-0.5mm RGB",
        "url": "https://3d.iconem.com/syria/DuraEuropos_Synagogue/DuraEuropos_Synagogue_W_0.5mm_RGB_fakegeo.cog.tiff",
        "type": "cog",
        "description": ""
      }
    ]
  }
}
